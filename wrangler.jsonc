{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "store",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-07-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"minify": true,
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "NEXT_CACHE_WORKERS_KV",
			"id": "53cd3efd253247d9855ba8e68e4552df"
		}
	]
}