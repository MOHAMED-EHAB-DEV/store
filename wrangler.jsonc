{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-store",
	"main": ".open-next/worker.js",
	"compatibility_date": "2024-09-23",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "my_store_cache",
			"id": "53cd3efd253247d9855ba8e68e4552df"
		}
	]
}